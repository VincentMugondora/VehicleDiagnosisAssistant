# Supabase
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-key

# AI Provider (cohere or gemini)
AI_PROVIDER=cohere

# Cohere AI
COHERE_API_KEY=your-cohere-api-key-here
COHERE_MODEL=command-r

# Gemini AI (legacy, optional)
GEMINI_API_KEY=AIzaSyxxx
GEMINI_MODEL=gemini-1.5-flash

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_VALIDATE_SIGNATURE=true
TWILIO_SEND_REPLY=false

# WhatsApp (Baileys)
BAILEYS_API_KEY=

# App Config
APP_ENV=development
LOG_LEVEL=INFO
SESSION_TTL_SECONDS=1800
MAX_CONVERSATION_TURNS=10

# Reply formatting
REPLY_MAX_CAUSES=5
REPLY_MAX_CHECKS=5
REPLY_MAX_CODES=3

# Feature Flags
AI_ENRICH_ENABLED=true
INTERNET_FALLBACK_ENABLED=true

# Usage Limits
USAGE_LIMIT_PER_NUMBER=20
USAGE_LIMIT_WINDOW_DAYS=30
ALLOWED_NUMBERS=whatsapp:+263,whatsapp:+5678

# External Search
SEARCH_PROVIDER=brave
BRAVE_API_KEY=
SERPAPI_KEY=
TRUSTED_SITES=obd-codes.com,autocodes.com,obdii.com
EXTERNAL_CACHE_TTL_SECONDS=2592000
EXTERNAL_ENRICH_ALWAYS=true
EXTERNAL_SAVE_PER_VEHICLE=false
