# Supabase
SUPABASE_URL=your-project-url-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# AI Provider (cohere or gemini)
AI_PROVIDER=cohere

# Cohere AI (primary)
COHERE_API_KEY=your-cohere-api-key-here
COHERE_MODEL=command-r-plus-08-2024

# Gemini AI (used as automatic fallback when AI_PROVIDER=cohere)
# If Cohere fails or is unavailable, Gemini will be used as backup
GEMINI_API_KEY=AQ.your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-exp

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_VALIDATE_SIGNATURE=true
TWILIO_SEND_REPLY=false

# WhatsApp (Baileys)
BAILEYS_API_KEY=

# App Config
APP_ENV=development
LOG_LEVEL=INFO
SESSION_TTL_SECONDS=1800
MAX_CONVERSATION_TURNS=10

# Reply formatting
REPLY_MAX_CAUSES=5
REPLY_MAX_CHECKS=5
REPLY_MAX_CODES=3

# Feature Flags
AI_ENRICH_ENABLED=true
INTERNET_FALLBACK_ENABLED=true

# Usage Limits
USAGE_LIMIT_PER_NUMBER=20
USAGE_LIMIT_WINDOW_DAYS=30
ALLOWED_NUMBERS=whatsapp:+263,whatsapp:+5678

# External Search
SEARCH_PROVIDER=brave
BRAVE_API_KEY=
SERPAPI_KEY=
TRUSTED_SITES=obd-codes.com,autocodes.com,obdii.com
EXTERNAL_CACHE_TTL_SECONDS=2592000
EXTERNAL_ENRICH_ALWAYS=true
EXTERNAL_SAVE_PER_VEHICLE=false

# Paynow Payments (Client credentials - DO NOT commit real values)
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_RETURN_URL=https://your-domain.com/payments/return
PAYNOW_RESULT_URL=https://your-domain.com/webhook/paynow

# Payment Config
SUBSCRIPTION_PRICE=2.00
FREE_DIAGNOSTICS_LIMIT=5
FREE_DIAGNOSTICS_WINDOW_DAYS=7
