# Fix for Cohere model name
# Replace the COHERE_MODEL line in your .env with one of these:

# Option 1: Command R Plus (Most capable - recommended for auto-learn)
COHERE_MODEL=command-r-plus

# Option 2: Command R (Good balance - faster and cheaper)
# COHERE_MODEL=command-r

# Option 3: Command Light (Fastest and cheapest)
# COHERE_MODEL=command-light

# Your current (WRONG):
# COHERE_MODEL=command-r-plus-08-2025  ❌ This doesn't exist!
